# Copy this file to ".env" (same folder) and replace the placeholder below with
# your real Groq API key. The ".env" file is gitignored, so your real key is
# never committed to version control. This ".env.example" is safe to share - it
# only documents WHICH variable to set, not the secret itself.
#
# Get a free key at: https://console.groq.com/keys

GROQ_API_KEY=gsk_your_key_here
