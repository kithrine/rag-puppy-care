# Secrets - NEVER commit your real API key.
# Your key lives in .env (created from .env.example); this line keeps it local.
.env

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Frontend (web/) - installed deps and build output are never committed
web/node_modules/
web/dist/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
